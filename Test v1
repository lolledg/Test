            game:GetService("ReplicatedStorage"):WaitForChild("MainEvent"):FireServer("Grabbing", false)
            wait(0.3)
            isHoverboarding = true
            AnimPlayvv2("3695333486", 1.0, 0, 0.3)
            local hoverConnection
            hoverConnection = game:GetService('RunService').Heartbeat:Connect(function()
                if not isHoverboarding or not _LocalPlayer2.Character or not victim or not victim.Parent then
