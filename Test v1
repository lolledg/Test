                        victimRoot.CFrame = playerRoot.CFrame * CFrame.new(0, -3, 0) * CFrame.Angles(math.rad(90), 0, 0)
                        victimRoot.Velocity = Vector3.zero
                        victimRoot.AssemblyLinearVelocity = Vector3.zero
