                    bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                    bodyGyro.P = 10000
                    bodyGyro.Parent = upperTorso
                end
                local playerCF = _LocalPlayer2.Character.HumanoidRootPart.CFrame
                local frontPos = playerCF.Position + (playerCF.LookVector * 2.5)
                bodyPos.Position = frontPos
                bodyGyro.CFrame = CFrame.new(frontPos) * CFrame.Angles(0, math.pi, 0)
            end)

            -- Cortar miembros serverside via BreakJoints
            local cutAnim = Instance.new('Animation')
            cutAnim.AnimationId = 'rbxassetid://126796684932532'

            local limbsToSever = { 'RightUpperArm', 'LeftUpperArm', 'LeftUpperLeg', 'RightUpperLeg' }

            for i = 1, 4 do
                local soundId = i == 4 and '91676414066995' or '125856818464345'
                if _LocalPlayer2.Character:FindFirstChild('BOOMBOX') then
                    _ReplicatedStorage.MainEvent:FireServer('Boombox', soundId)
                else
                    local cutSound = Instance.new("Sound")
                    cutSound.SoundId = "rbxassetid://" .. soundId
                    cutSound.Volume = 0.8
                    cutSound.Parent = workspace
                    cutSound:Play()
                    game.Debris:AddItem(cutSound, 3)
                end

                local cutTrack = _LocalPlayer2.Character.Humanoid:LoadAnimation(cutAnim)
                cutTrack:Play()
                cutTrack:AdjustSpeed(1.2)

                if knifeVictim and knifeVictim.Parent then
                    local part = knifeVictim:FindFirstChild(limbsToSever[i])
                    if part then
                        -- Serverside: romper joint de la parte en vez de destruirla clientside
                        BreakPartJoints(part)
                        part.CanCollide = false
                        part.Massless = true
                        -- Lanzar la parte lejos para que desaparezca
                        part.AssemblyLinearVelocity = Vector3.new(
                            math.random(-20, 20), math.random(10, 30), math.random(-20, 20)
                        )
                    end
                end

                if math.random(1, 3) == 1 then PlayLaugh() end
                wait(1.5)
                cutTrack:Stop()
            end

            -- DEBUG: verificar que las partes fueron removidas, si no forzar ragdoll completo
            task.wait(0.2)
            if knifeVictim and knifeVictim.Parent then
                local allGone = true
                for _, limbName in ipairs(limbsToSever) do
                    local limb = knifeVictim:FindFirstChild(limbName)
                    -- Si la parte sigue conectada (tiene motor6D activo) entonces no se cortó bien
                    if limb then
                        local hasJoint = false
                        for _, v in pairs(limb:GetChildren()) do
                            if v:IsA('Motor6D') then hasJoint = true end
                        end
                        if hasJoint then allGone = false end
                    end
                end
                if not allGone then
                    -- Fallback: forzar ragdoll completo al personaje
                    ForceRagdoll(knifeVictim)
                end
            end

            -- Parar alineación antes de la cabeza
            stopAlign = true
            if alignConnection then alignConnection:Disconnect() end

            -- Limpiar BodyPosition/BodyGyro de la víctima
            if knifeVictim and knifeVictim.Parent then
                local upperTorso = knifeVictim:FindFirstChild('UpperTorso')
                if upperTorso then
                    local bp = upperTorso:FindFirstChild('BodyPosition')
                    local bg = upperTorso:FindFirstChild('BodyGyro')
                    if bp then bp:Destroy() end
                    if bg then bg:Destroy() end
                end
            end

            -- === CABEZA SERVERSIDE ===
            -- En vez de clonar clientside, usamos la cabeza real de la víctima
            -- La desconectamos del cuerpo rompiendo su joint y la weldeamos al brazo del jugador
            if knifeVictim and knifeVictim.Parent and knifeVictim:FindFirstChild('Head') then
                local victimHead = knifeVictim.Head
                local rightHand = _LocalPlayer2.Character:FindFirstChild('RightHand') or
                                  _LocalPlayer2.Character:FindFirstChild('Right Arm')

                -- Romper joint de la cabeza del cuerpo víctima (serverside)
                BreakPartJoints(victimHead)
                -- Destruir el neck motor del torso también
                local upperTorso = knifeVictim:FindFirstChild('UpperTorso')
                if upperTorso then
                    for _, v in pairs(upperTorso:GetChildren()) do
                        if v:IsA('Motor6D') and (v.Name == 'Neck' or v.Part1 == victimHead or v.Part0 == victimHead) then
                            v:Destroy()
                        end
                    end
                end

                victimHead.CanCollide = false
                victimHead.Massless = true

                -- Weld la cabeza real a la mano del jugador
                if rightHand then
                    victimHead.CFrame = rightHand.CFrame * CFrame.new(0, 0, -0.5)
                    local headWeld = Instance.new('Weld')
                    headWeld.Part0 = rightHand
                    headWeld.Part1 = victimHead
                    headWeld.C0 = CFrame.new(0, 0, -0.5)
                    headWeld.Parent = victimHead
                end

                PlayLaugh()
                wait(1)

                -- Soltar la cabeza al piso
                local headWeldInst = victimHead:FindFirstChildOfClass('Weld')
                if headWeldInst then headWeldInst:Destroy() end

                -- Posicionar en el suelo frente al jugador
                local groundPos = _LocalPlayer2.Character.HumanoidRootPart.Position
                victimHead.CFrame = CFrame.new(groundPos.X, groundPos.Y - 2.5, groundPos.Z - 2)
                victimHead.CanCollide = true
                victimHead.Massless = false
                victimHead.Anchored = true

                -- Efecto de sangre en el suelo
                local bloodPool = Instance.new("Part")
                bloodPool.Size = Vector3.new(2, 0.1, 2)
                bloodPool.BrickColor = BrickColor.new("Bright red")
                bloodPool.Material = Enum.Material.Neon
                bloodPool.Transparency = 0.6
                bloodPool.CanCollide = false
                bloodPool.Anchored = true
                bloodPool.CFrame = victimHead.CFrame * CFrame.new(0, -0.5, 0)
                bloodPool.Parent = workspace
                game.Debris:AddItem(bloodPool, 4)
                game.Debris:AddItem(victimHead, 6)
            end

            -- Animación de pisoteo
            local stompAnim = Instance.new('Animation')
            stompAnim.AnimationId = 'rbxassetid://72406748336709'
            local stompTrack = _LocalPlayer2.Character.Humanoid:LoadAnimation(stompAnim)
            stompTrack:Play()
            PlayLaugh()
            wait(1.5)
            stompTrack:Stop()

            -- Soltar al jugador agarrado
            game:GetService("ReplicatedStorage"):WaitForChild("MainEvent"):FireServer("Grabbing", false)

            -- Devolver cuchillo al backpack
            if knife and knife.Parent == _LocalPlayer2.Character then
                knife.Parent = _LocalPlayer2.Backpack
            end

            freezeTrack:Stop()
            freezeAnim:Destroy()
            cutAnim:Destroy()

            game:GetService('StarterGui'):SetCore('SendNotification', {
                Title = '💀 EXECUTION COMPLETE',
                Text = victimPlayer.Name .. ' has been eliminated',
                Duration = 4
            })

            isKnifeActive = false
            knifeVictim = nil
        end)

        -- HOVERBOARD TOOL
        if _LocalPlayer2.Backpack:FindFirstChild('hoverboard') then
            _LocalPlayer2.Backpack:FindFirstChild('hoverboard'):Destroy()
        end
        if _LocalPlayer2.Character:FindFirstChild('hoverboard') then
            _LocalPlayer2.Character:FindFirstChild('hoverboard'):Destroy()
        end
        wait(0.1)
        isHoverboarding = false
        local hoverboardTool = Instance.new('Tool')
        hoverboardTool.RequiresHandle = false
        hoverboardTool.Name = 'hoverboard'
        hoverboardTool.ToolTip = 'Hoverboard - Monta víctimas como tabla'
        hoverboardTool.Parent = _LocalPlayer2.Backpack

        hoverboardTool.Activated:Connect(function()
            if isHoverboarding then
                isHoverboarding = false
                game:GetService('StarterGui'):SetCore('SendNotification', {
                    Title = '🛹 Hoverboard',
                    Text = 'Desmontado',
                    Duration = 2
                })
